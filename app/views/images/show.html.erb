<div class="container">
  <div class="overlay noise"></div>
  <div class="overlay stars"></div>

<% if @image.status == 'failed' %>
  <div class="processing-state">
    <p class="processing-message error">Something went wrong while processing your photo.</p>
    <a href="/" class="pill-btn secondary" style="margin-top: 2cqw;">Try another image</a>
  </div>

<% elsif @image.ready? %>
  <div class="result-actions" style="position: absolute; bottom: 5%; left: 5%; z-index: 50; display: flex; flex-direction: column; gap: 2cqw;">
    <a href="<%= download_path(@image) %>" class="pill-btn primary" style="padding: 1.35cqw 4cqw; font-size: 2.4cqw;">
      Download 2048px
    </a>
    <a href="/" class="pill-btn secondary" style="margin-left: 0; padding: 1.1cqw 2.7cqw; font-size: 1.6cqw;">
      Soften another one
    </a>
  </div>

  <div class="comparison-container">
    <div class="image-comparison-frame">
      <div class="image-comparison" id="image-comparison">
        <div class="image-before">
          <img src="<%= @image.file.url(:half) %>" alt="Before">
        </div>
        <div class="image-after">
          <img src="<%= @image.file.url(:halfsoft) %>" alt="After">
        </div>
        <div class="comparison-slider">
          <div class="slider-line"></div>
          <div class="slider-button">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
          </div>
        </div>
      </div>
    </div>
  </div>

<% else %>
  <div class="processing-state" id="processing-state">
    <div class="spinner"></div>
    <p class="processing-message">Applying soft focus…</p>
    <p class="processing-sub">This usually takes a few seconds</p>
  </div>

  <script>
    (function poll() {
      fetch('<%= image_status_path(@image) %>')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.status === 'ready' || data.status === 'failed') {
            window.location.reload();
          } else {
            setTimeout(poll, 2000);
          }
        })
        .catch(function() { setTimeout(poll, 3000); });
    })();
  </script>
<% end %>
</div>

<style>
.processing-state {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2cqw;
  z-index: 10;
}

.processing-message {
  color: white;
  font-size: 3cqw;
  font-family: 'Fraunces', serif;
  text-align: center;
  text-shadow: 0 2px 8px rgba(0,0,0,0.5);
}

.processing-message.error {
  color: #ff8080;
}

.processing-sub {
  color: rgba(255,255,255,0.6);
  font-size: 1.6cqw;
  font-family: 'Inter', sans-serif;
  text-align: center;
}

.spinner {
  width: 5cqw;
  height: 5cqw;
  border: 0.4cqw solid rgba(255,255,255,0.2);
  border-top-color: white;
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.comparison-container {
  position: absolute;
  top: 50%;
  right: 5%;
  transform: translateY(-50%);
  width: 50cqw;
  height: 50cqw;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 5;
}

.image-comparison-frame {
  position: relative;
  width: 100%;
  height: 100%;
  padding: 1cqw;
  border-radius: 3cqw;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.15) 0%, rgba(255, 255, 255, 0.05) 100%);
  backdrop-filter: blur(1.5cqw);
  -webkit-backdrop-filter: blur(1.5cqw);
  box-shadow:
    0 4cqw 8cqw rgba(0, 0, 0, 0.4),
    inset 0 0.1cqw 0.3cqw rgba(255, 255, 255, 0.6),
    0 0 0 0.1cqw rgba(255, 255, 255, 0.2),
    0 0 5cqw rgba(255, 180, 200, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.image-comparison {
  position: relative;
  width: 100%;
  height: 100%;
  border-radius: 2cqw;
  overflow: hidden;
  box-shadow: inset 0 0 1cqw rgba(0,0,0,0.5), 0 1cqw 3cqw rgba(0,0,0,0.3);
  user-select: none;
  -webkit-user-select: none;
}

.image-comparison img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  background: rgba(0,0,0,0.5);
  display: block;
  pointer-events: none;
  -webkit-user-drag: none;
}

.image-before {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.image-after {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 2;
  clip-path: inset(0 0 0 50%);
}

.comparison-slider {
  position: absolute;
  top: 0;
  left: 50%;
  width: 0.2cqw;
  height: 100%;
  background: white;
  z-index: 3;
  cursor: ew-resize;
}

.slider-line {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  width: 0.3cqw;
  height: 100%;
  background: rgba(255,255,255,0.8);
  box-shadow: 0 0 1cqw rgba(0,0,0,0.5);
}

.slider-button {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 4cqw;
  height: 4cqw;
  background: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 0.5cqw;
  box-shadow: 0 0.5cqw 1.5cqw rgba(0,0,0,0.3);
  color: #333;
}

.slider-button svg {
  width: 1.5cqw;
  height: 1.5cqw;
}

.result-page .title {
  font-size: 5cqw;
}
</style>

<% if @image.ready? %>
<script>
document.addEventListener('DOMContentLoaded', () => {
  const container = document.getElementById('image-comparison');
  const slider = container.querySelector('.comparison-slider');
  const afterImage = container.querySelector('.image-after');
  let isResizing = false;

  const moveSlider = (e) => {
    if (!isResizing) return;

    let x;
    if (e.type === 'touchmove') {
      x = e.touches[0].clientX - container.getBoundingClientRect().left;
    } else {
      x = e.clientX - container.getBoundingClientRect().left;
    }

    let position = (x / container.offsetWidth) * 100;

    if (position < 0) position = 0;
    if (position > 100) position = 100;

    slider.style.left = `${position}%`;
    afterImage.style.clipPath = `inset(0 0 0 ${position}%)`;
  };

  slider.addEventListener('mousedown', (e) => {
    isResizing = true;
    e.preventDefault();
  });
  window.addEventListener('mouseup', () => isResizing = false);
  window.addEventListener('mousemove', moveSlider);

  slider.addEventListener('touchstart', () => isResizing = true);
  window.addEventListener('touchend', () => isResizing = false);
  window.addEventListener('touchmove', moveSlider);

  container.addEventListener('dragstart', (e) => e.preventDefault());
});
</script>
<% end %>
